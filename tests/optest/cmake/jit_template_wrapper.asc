// ---------------------------------------------------------------------------
// JIT template compilation-check wrapper
//
// This file is a static wrapper used exclusively in CMake try_compile to
// verify that a JIT template (.cpp) can be compiled by bisheng (ASC compiler).
//
// TEMPLATE_PATH must be defined on the command line via -D, e.g.:
//   bisheng -DTEMPLATE_PATH=basic_matmul_impl.cpp ...
//
// The preprocessor uses the # operator (stringification) to expand the macro
// into a quoted string for #include. This avoids any CMake file generation.
// ---------------------------------------------------------------------------

#define ASC_STR_IMPL(x) #x
#define ASC_INCLUDE(x) ASC_STR_IMPL(x)

#include ASC_INCLUDE(TEMPLATE_PATH)

int main() { return 0; }
